{
  "info": {
    "_postman_id": "7a364354-c6b0-4f8e-9dad-5f4c5979844b",
    "name": "Boxing Backend API",
    "description": "Postman collection for the Boxing Backend session, command, frame, status, and stream endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.collectionVariables.get('base_url')) {",
          "  pm.collectionVariables.set('base_url', 'http://127.0.0.1:5001');",
          "}",
          "if (!pm.collectionVariables.get('frame_path')) {",
          "  pm.collectionVariables.set('frame_path', '/Users/blue1/Documents/Slapback/boxing-rover/backend/app/static/images/output2.png');",
          "}"
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:5001"
    },
    {
      "key": "session_id",
      "value": ""
    },
    {
      "key": "event_id",
      "value": ""
    },
    {
      "key": "frame_path",
      "value": "/Users/blue1/Documents/Slapback/boxing-rover/backend/app/static/images/output2.png"
    },
    {
      "key": "frame_base64",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/health",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "health"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Health returns 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('Health body is ok', function () {",
              "  var data = pm.response.json();",
              "  pm.expect(data.status).to.eql('ok');",
              "});"
            ]
          }
        }
      ],
      "response": []
    },
    {
      "name": "Create Session",
      "request": {
        "method": "POST",
        "header": [],
        "url": {
          "raw": "{{base_url}}/sessions",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "sessions"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Create session returns 201', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "var data = pm.response.json();",
              "pm.collectionVariables.set('session_id', data.session_id);",
              "pm.test('Session id was captured', function () {",
              "  pm.expect(pm.collectionVariables.get('session_id')).to.have.length.above(0);",
              "});"
            ]
          }
        }
      ],
      "response": []
    },
    {
      "name": "Get Session Status",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/sessions/{{session_id}}/status",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "sessions",
            "{{session_id}}",
            "status"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status returns 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('Status includes session id', function () {",
              "  var data = pm.response.json();",
              "  pm.expect(data.session_id).to.eql(pm.collectionVariables.get('session_id'));",
              "});"
            ]
          }
        }
      ],
      "response": []
    },
    {
      "name": "Send MOVE Command",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"command\": \"MOVE\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/sessions/{{session_id}}/command",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "sessions",
            "{{session_id}}",
            "command"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('MOVE returns 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('MOVE returns movement target', function () {",
              "  var data = pm.response.json();",
              "  pm.expect(data.status).to.eql('OK');",
              "  pm.expect(data.movement_target).to.be.an('object');",
              "});"
            ]
          }
        }
      ],
      "response": []
    },
    {
      "name": "Send LEFT Punch Command",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"command\": \"PUNCH_REQUEST_LEFT\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/sessions/{{session_id}}/command",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "sessions",
            "{{session_id}}",
            "command"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('LEFT punch command returns 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "var data = pm.response.json();",
              "pm.collectionVariables.set('event_id', data.event_id || '');",
              "pm.test('LEFT punch transitions to waiting state', function () {",
              "  pm.expect(data.state).to.eql('WAITING_FOR_LEFT');",
              "});"
            ]
          }
        }
      ],
      "response": []
    },
    {
      "name": "Send RIGHT Punch Command (Typo Alias)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"command\": \"PUNSH_REQUEST_RIGHT\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/sessions/{{session_id}}/command",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "sessions",
            "{{session_id}}",
            "command"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Typo alias command still returns 200 or MOVING', function () {",
              "  pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ],
      "response": []
    },
    {
      "name": "Upload Frame (Multipart)",
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "frame",
              "type": "file",
              "src": "{{frame_path}}"
            }
          ]
        },
        "url": {
          "raw": "{{base_url}}/sessions/{{session_id}}/frames",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "sessions",
            "{{session_id}}",
            "frames"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Multipart frame upload returns 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('Frame upload returns a state', function () {",
              "  var data = pm.response.json();",
              "  pm.expect(data.state).to.be.a('string');",
              "});"
            ]
          }
        }
      ],
      "response": []
    },
    {
      "name": "Upload Frame (Base64 JSON)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"frame_base64\": \"{{frame_base64}}\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/sessions/{{session_id}}/frames",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "sessions",
            "{{session_id}}",
            "frames"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Base64 frame upload returns 200 or 400 if frame_base64 is unset', function () {",
              "  pm.expect([200, 400]).to.include(pm.response.code);",
              "});"
            ]
          }
        }
      ],
      "response": []
    },
    {
      "name": "Get Debug Stream",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/sessions/{{session_id}}/stream",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "sessions",
            "{{session_id}}",
            "stream"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Stream endpoint responds', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('Stream content type is multipart', function () {",
              "  pm.expect(pm.response.headers.get('Content-Type')).to.include('multipart/x-mixed-replace');",
              "});"
            ]
          }
        }
      ],
      "response": []
    }
  ]
}
